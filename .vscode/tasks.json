{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "coach-web: dev",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/uvicorn",
      "args": [
        "coach.web.app:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
