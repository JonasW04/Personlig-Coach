# Copy to .env and fill in.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Hevy Pro -> https://hevy.com/settings?developer
HEVY_API_KEY=

# Strava API app -> https://www.strava.com/settings/api
# Set the app's "Authorization Callback Domain" to: localhost
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Withings app -> https://developer.withings.com/
# Register the callback URL exactly as: http://localhost:8722/callback
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=

# Postgres. Local dev uses Homebrew trust auth (no password) as your OS user.
# Note port 5433: 5432 was occupied by another server on this machine.
DATABASE_URL=postgresql+psycopg://jonaswiger@localhost:5433/coach

# Models (Sonnet for routine reasoning, Opus for weekly review)
COACH_MODEL=claude-sonnet-4-6
COACH_REVIEW_MODEL=claude-opus-4-7

# Email for the weekly review (SMTP, STARTTLS on port 587).
# Gmail: use an App Password (https://myaccount.google.com/apppasswords) as SMTP_PASSWORD.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# Notion (optional). Create an internal integration at
# https://www.notion.so/my-integrations, share a parent page with it, and paste the
# page id below. Reviews/readiness briefs are added as child pages. Leave blank to skip.
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=

# --- Web app (the dashboard) ---
# Single-user login. Pick a username and a strong password.
APP_USERNAME=me
APP_PASSWORD=
# Signs the session cookie. Generate one: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=dev-insecure-change-me

# Server bind. Locally 127.0.0.1:8000 is fine; in Docker/Railway use HOST=0.0.0.0 and
# let the platform inject PORT.
HOST=127.0.0.1
PORT=8000

# In-process scheduler (nightly sync 03:00, readiness 06:00, weekly review Sun 18:00).
# Turn on for the always-on web service; set your timezone (e.g. Europe/Stockholm).
RUN_SCHEDULER=false
SCHEDULER_TIMEZONE=UTC
